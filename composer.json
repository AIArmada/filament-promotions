{
    "name": "aiarmada/filament-promotions",
    "description": "A Filament v5 plugin for administering promotions provided by the AIArmada promotions package",
    "license": "MIT",
    "homepage": "https://github.com/aiarmada/commerce",
    "support": {
        "issues": "https://github.com/aiarmada/commerce/issues",
        "source": "https://github.com/aiarmada/commerce"
    },
    "require": {
        "aiarmada/commerce-support": "self.version",
        "aiarmada/promotions": "self.version",
        "filament/filament": "^5.6.7",
        "php": "^8.4"
    },
    "suggest": {
        "aiarmada/filament-cart": "Enables deep linking from promotion usage to cart snapshots",
        "aiarmada/filament-products": "Enables product-based promotion targeting"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentPromotions\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentPromotions\\FilamentPromotionsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
